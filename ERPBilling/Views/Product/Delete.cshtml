@model ERPBilling.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm" style="border:1px solid #dc3545!important">
            <div class="card-header bg-danger text-white border-0">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to delete this product?</p>

                <table class="table table-sm table-borderless mb-4">
                    <tr><td class="text-muted">Name</td><td class="fw-semibold">@Model.Name</td></tr>
                    <tr><td class="text-muted">Category</td><td>@(Model.Category ?? "—")</td></tr>
                    <tr><td class="text-muted">Unit Price</td><td>₹@Model.UnitPrice.ToString("N2")</td></tr>
                    <tr><td class="text-muted">Tax</td><td>@Model.TaxPercent%</td></tr>
                </table>

                <div class="alert alert-warning small">
                    <i class="bi bi-info-circle me-1"></i>
                    Products used in existing invoices cannot be deleted.
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

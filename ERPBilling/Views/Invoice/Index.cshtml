@model IEnumerable<ERPBilling.Models.Invoice>
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Invoices</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>New Invoice
    </a>
</div>

<!-- Status Filter Tabs -->
<div class="mb-3">
    <a asp-action="Index"
       class="btn btn-sm me-1 @(ViewBag.CurrentStatus == null ? "btn-dark" : "btn-outline-secondary")">
        All
    </a>
    <a asp-action="Index" asp-route-status="Paid"
       class="btn btn-sm me-1 @(ViewBag.CurrentStatus == "Paid" ? "btn-success" : "btn-outline-success")">
        Paid
    </a>
    <a asp-action="Index" asp-route-status="Unpaid"
       class="btn btn-sm me-1 @(ViewBag.CurrentStatus == "Unpaid" ? "btn-danger" : "btn-outline-danger")">
        Unpaid
    </a>
    <a asp-action="Index" asp-route-status="Partial"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Partial" ? "btn-warning" : "btn-outline-warning")">
        Partial
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Invoice #</th>
                    <th>Customer</th>
                    <th>Invoice Date</th>
                    <th>Due Date</th>
                    <th>Amount</th>
                    <th>Paid</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    var paid = inv.Payments.Sum(p => p.AmountPaid);
                    var balance = inv.TotalAmount - paid;
                    var isOverdue = inv.Status != ERPBilling.Models.InvoiceStatus.Paid
                    && inv.DueDate < DateTime.Today;
                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td class="fw-semibold">@inv.InvoiceNumber</td>
                        <td>@inv.Customer?.Name</td>
                        <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @inv.DueDate.ToString("dd MMM yyyy")
                            @if (isOverdue)
                            {
                                <span class="badge bg-danger ms-1">Overdue</span>
                            }
                        </td>
                        <td>₹@inv.TotalAmount.ToString("N2")</td>
                        <td class="text-success">₹@paid.ToString("N2")</td>
                        <td class="@(balance > 0 ? "text-danger fw-semibold" : "text-muted")">
                            ₹@balance.ToString("N2")
                        </td>
                        <td>
                            @{
                                var badgeClass = inv.Status switch
                                {
                                    ERPBilling.Models.InvoiceStatus.Paid => "badge-paid",
                                    ERPBilling.Models.InvoiceStatus.Unpaid => "badge-unpaid",
                                    _ => "badge-partial"
                                };
                            }
                            <span class="badge @badgeClass">@inv.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@inv.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">
                            <i class="bi bi-file-earmark-text fs-3 d-block mb-2"></i>
                            No invoices found. <a asp-action="Create">Create your first invoice</a>.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

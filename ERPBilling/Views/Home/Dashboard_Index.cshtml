@model ERPBilling.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- ── Stat Cards ─────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 text-white h-100"
             style="background:linear-gradient(135deg,#0d6efd,#6ea8fe)">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 opacity-75 small">Total Revenue</p>
                    <h4 class="mb-0">₹@Model.TotalRevenue.ToString("N2")</h4>
                </div>
                <i class="bi bi-cash-stack fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 text-white h-100"
             style="background:linear-gradient(135deg,#dc3545,#f28a92)">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 opacity-75 small">Total Pending</p>
                    <h4 class="mb-0">₹@Model.TotalPending.ToString("N2")</h4>
                </div>
                <i class="bi bi-hourglass-split fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 text-white h-100"
             style="background:linear-gradient(135deg,#198754,#5cb85c)">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 opacity-75 small">Paid Invoices</p>
                    <h4 class="mb-0">@Model.TotalPaidInvoices</h4>
                </div>
                <i class="bi bi-check-circle fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 text-white h-100"
             style="background:linear-gradient(135deg,#fd7e14,#ffc107)">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-1 opacity-75 small">Unpaid / Partial</p>
                    <h4 class="mb-0">@(Model.TotalUnpaidInvoices + Model.TotalPartialInvoices)</h4>
                </div>
                <i class="bi bi-exclamation-circle fs-1 opacity-25"></i>
            </div>
        </div>
    </div>
</div>

<!-- ── Invoice Breakdown + Recent Invoices ──────────── -->
<div class="row g-3">

    <!-- Progress breakdown -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Invoice Breakdown</h6>
            </div>
            <div class="card-body">
                @{
                    int total = Model.TotalInvoices > 0 ? Model.TotalInvoices : 1;
                }
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-success fw-semibold">Paid</small>
                        <small>@Model.TotalPaidInvoices of @Model.TotalInvoices</small>
                    </div>
                    <div class="progress" style="height:10px">
                        <div class="progress-bar bg-success"
                             style="width:@(Model.TotalPaidInvoices * 100 / total)%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-danger fw-semibold">Unpaid</small>
                        <small>@Model.TotalUnpaidInvoices of @Model.TotalInvoices</small>
                    </div>
                    <div class="progress" style="height:10px">
                        <div class="progress-bar bg-danger"
                             style="width:@(Model.TotalUnpaidInvoices * 100 / total)%"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-warning fw-semibold">Partial</small>
                        <small>@Model.TotalPartialInvoices of @Model.TotalInvoices</small>
                    </div>
                    <div class="progress" style="height:10px">
                        <div class="progress-bar bg-warning"
                             style="width:@(Model.TotalPartialInvoices * 100 / total)%"></div>
                    </div>
                </div>

                <hr />
                <div class="d-grid gap-2">
                    <a asp-controller="Invoice" asp-action="Create"
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>New Invoice
                    </a>
                    <a asp-controller="Invoice" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                        View All Invoices
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent 5 Invoices -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Invoices</h6>
                <a asp-controller="Invoice" asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">View All</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.RecentInvoices)
                        {
                            <tr style="cursor:pointer"
                                onclick="window.location='@Url.Action("Details","Invoice", new { id = inv.Id })'">
                                <td class="fw-semibold text-primary">@inv.InvoiceNumber</td>
                                <td>@inv.Customer?.Name</td>
                                <td>@inv.InvoiceDate.ToString("dd MMM yy")</td>
                                <td>₹@inv.TotalAmount.ToString("N2")</td>
                                <td>
                                    @{
                                        var bc = inv.Status switch
                                        {
                                            ERPBilling.Models.InvoiceStatus.Paid => "badge-paid",
                                            ERPBilling.Models.InvoiceStatus.Unpaid => "badge-unpaid",
                                            _ => "badge-partial"
                                        };
                                    }
                                    <span class="badge @bc">@inv.Status</span>
                                </td>
                            </tr>
                        }
                        @if (!Model.RecentInvoices.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No invoices yet. <a asp-controller="Invoice" asp-action="Create">Create one</a>.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

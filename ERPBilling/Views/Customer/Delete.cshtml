@model ERPBilling.Models.Customer
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm border-danger" style="border:1px solid #dc3545!important">
            <div class="card-header bg-danger text-white border-0">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to delete this customer? This action cannot be undone.</p>

                <table class="table table-sm table-borderless mb-4">
                    <tr><td class="text-muted">Name</td><td class="fw-semibold">@Model.Name</td></tr>
                    <tr><td class="text-muted">Email</td><td>@Model.Email</td></tr>
                    <tr><td class="text-muted">Phone</td><td>@Model.Phone</td></tr>
                </table>

                @if (Model.Invoices.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        This customer has <strong>@Model.Invoices.Count invoice(s)</strong>.
                        You cannot delete them until all invoices are removed first.
                    </div>
                }

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        @if (!Model.Invoices.Any())
                        {
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

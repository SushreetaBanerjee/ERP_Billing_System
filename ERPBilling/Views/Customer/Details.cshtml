@model ERPBilling.Models.Customer
@{ ViewData["Title"] = "Customer Details"; }

<div class="row">
    <!-- Customer Info Card -->
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                         style="width:48px;height:48px;font-size:18px;font-weight:600">
                        @Model.Name[0]
                    </div>
                    <div>
                        <h6 class="mb-0">@Model.Name</h6>
                        <small class="text-muted">Customer #@Model.Id</small>
                    </div>
                </div>

                <hr />

                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted">Email</td>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Phone</td>
                        <td>@Model.Phone</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Address</td>
                        <td>@(Model.Address ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">GST No.</td>
                        <td>
                            @if (!string.IsNullOrEmpty(Model.GSTNumber))
                            { <code>@Model.GSTNumber</code> }
                            else
                            { <span>—</span> }
                        </td>
                    </tr>
                </table>

                <hr />
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Invoice History -->
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Invoice History</h6>
                <span class="badge bg-secondary">@Model.Invoices.Count invoices</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Invoices.OrderByDescending(i => i.InvoiceDate))
                        {
                            <tr>
                                <td class="fw-semibold">@inv.InvoiceNumber</td>
                                <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td>₹@inv.TotalAmount.ToString("N2")</td>
                                <td>
                                    @{
                                        var cls = inv.Status == ERPBilling.Models.InvoiceStatus.Paid ? "badge-paid"
                                                : inv.Status == ERPBilling.Models.InvoiceStatus.Unpaid ? "badge-unpaid"
                                                : "badge-partial";
                                    }
                                    <span class="badge @cls">@inv.Status</span>
                                </td>
                                <td>
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@inv.Id"
                                       class="btn btn-sm btn-outline-info">View</a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Invoices.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No invoices for this customer yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

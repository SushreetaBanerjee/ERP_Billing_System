@*
  _EmptyState.cshtml — reusable empty-state partial.
  Usage:
  @await Html.PartialAsync("_EmptyState", new EmptyStateModel(
      Icon: "bi-receipt",
      Title: "No invoices yet",
      Subtitle: "Create your first invoice to start billing customers.",
      ActionText: "Create Invoice",
      ActionUrl: Url.Action("Create", "Invoice")
  ))
*@
@model ERPBilling.Models.EmptyStateModel

<div class="text-center py-5">
    <i class="bi @Model.Icon" style="font-size: 2.5rem; color:#c9d3e0;"></i>
    <h6 class="mt-3 mb-1 text-secondary fw-semibold">@Model.Title</h6>
    <p class="text-muted small mb-3">@Model.Subtitle</p>
    @if (!string.IsNullOrEmpty(Model.ActionUrl))
    {
        <a href="@Model.ActionUrl" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-circle me-1"></i>@Model.ActionText
        </a>
    }
</div>
